{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wyvern.world_state.v1.schema.json",
  "title": "Wyvern World State v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "state_id",
    "trace_id",
    "vehicle_id",
    "mission_id",
    "objects",
    "hazards",
    "landmarks",
    "pose_mode",
    "updated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "wyvern.world_state.v1"
    },
    "state_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "vehicle_id": {
      "type": "string"
    },
    "mission_id": {
      "type": "string"
    },
    "objects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "hazards": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "landmarks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "pose_mode": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
